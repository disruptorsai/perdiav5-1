# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI API Keys - Option 1: OpenRouter (recommended - single key for all models)
VITE_OPENROUTER_API_KEY=your-openrouter-key-here

# AI API Keys - Option 2: Direct API keys (used if OpenRouter key not set)
VITE_GROK_API_KEY=your-grok-api-key-here
VITE_CLAUDE_API_KEY=your-claude-api-key-here

# StealthGPT for content humanization (optional)
VITE_STEALTHGPT_API_KEY=your-stealthgpt-key-here

# DataForSEO API Credentials (optional)
VITE_DATAFORSEO_USERNAME=your-dataforseo-username
VITE_DATAFORSEO_PASSWORD=your-dataforseo-password

# Notes:
# 1. Copy this file to .env.local and fill in your actual values
# 2. Never commit .env.local to version control
# 3. Get Supabase credentials from: https://app.supabase.com
# 4. Get OpenRouter API key from: https://openrouter.ai/keys (recommended)
# 5. Or get individual API keys:
#    - Grok API key from: https://console.x.ai
#    - Claude API key from: https://console.anthropic.com
# 6. Get DataForSEO credentials from: https://app.dataforseo.com
